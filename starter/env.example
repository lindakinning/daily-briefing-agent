# Copy this file to .env and fill in your key:
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows)

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — override the model set in config.yaml
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — only needed if you build a Todoist writer (see FINISH-ON-YOUR-OWN.md, Step 3)
# TODOIST_API_TOKEN=your-todoist-token-here
